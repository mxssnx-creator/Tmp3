# Vercel Build Ignore File
# Prevents unnecessary files from being included in deployment

# Documentation
*.md
docs/
.github/
.gitignore
LICENSE

# Development files
.env.local
.env.*.local
.env.example
.eslintrc*
.prettierrc*
.editorconfig

# Build artifacts (cleaned before deploy)
dist/
build/
*.tsbuildinfo
.turbo/

# Dependencies (regenerated during install)
node_modules/
pnpm-lock.yaml
yarn.lock
package-lock.json

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
__tests__/
.test.ts
*.test.ts
*.spec.ts
coverage/
.nyc_output/

# Backup & Temporary
*.bak
*.tmp
*.log
tmp/
temp/
backup/

# Git
.git/
.gitattributes

# CI/CD
.github/workflows/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Keep only production-essential files
# .next/ - needed
# public/ - needed
# lib/ - needed
# app/ - needed
# components/ - needed
# scripts/vercel-build-setup.sh - needed
