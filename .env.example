# CTS v3.1 - Environment Variables
# Copy this file to .env.local and fill in the values

# Application
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Security - Generate secure random strings (min 32 chars)
JWT_SECRET=your-jwt-secret-min-32-characters-long
SESSION_SECRET=your-session-secret-min-32-chars
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Database (SQLite by default, or PostgreSQL)
DATABASE_URL=file:./data/cts.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/cts_db

# Redis (optional - for caching)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Exchange API Keys (fill in for each exchange you use)
# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# BingX
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_TESTNET=true

# Pionex
PIONEX_API_KEY=
PIONEX_API_SECRET=

# OKX
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=true

# OrangeX
ORANGEX_API_KEY=
ORANGEX_API_SECRET=

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
